# Hybrid Athlete Tracker — backend environment
# Copy to backend/.env and fill in. Do NOT commit .env (it's gitignored).

PORT=3000

# Supabase project credentials (Dashboard -> Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key bypasses RLS — keep it secret, server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini API key for AI tips/coach (optional; coach is disabled if blank)
GEMINI_API_KEY=
